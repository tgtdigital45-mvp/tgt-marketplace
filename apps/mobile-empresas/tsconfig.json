{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*", "./src/*"],
      "@/hooks/*": ["./hooks/*", "./src/hooks/*"],
      "@/providers/*": ["./providers/*", "./src/providers/*"],
      "@/contexts/*": ["./contexts/*", "./src/contexts/*"],
      "@/components/*": ["./components/*", "./src/components/*"],
      "@/utils/*": ["./utils/*", "./src/utils/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".expo",
    "supabase/functions"
  ]
}